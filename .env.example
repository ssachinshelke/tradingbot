# ── MT5 Connection ────────────────────────────────────────────
MT5_LOGIN=0000000000
MT5_PASSWORD=your_password_here
MT5_SERVER=MetaQuotes-Demo
# Full path to terminal64.exe (run: python tests/run_test.py discover-terminal)
MT5_PATH=
MT5_PORTABLE=false

# ── Multi-Account ─────────────────────────────────────────────
ACCOUNTS_FILE=accounts.json
DISPATCH_JOURNAL_PATH=dispatch_journal.csv
SYNC_SEND_DELAY_MS=300

# ── Trading Defaults ──────────────────────────────────────────
DEFAULT_SYMBOL=EURUSD
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_OPEN_TRADES=3
SL_PIPS=25
TP_PIPS=50
DEVIATION=20
MAGIC_NUMBER=20260302

# ── Strategy ──────────────────────────────────────────────────
TIMEFRAME=M5
FAST_MA=20
SLOW_MA=50
STRATEGY_NAME=ma_cross
# Custom strategy – uncomment one:
# STRATEGY_CLASS_PATH=strategies.rsi_reversal:RSIReversalStrategy
# STRATEGY_CLASS_PATH=strategies.bollinger_bounce:BollingerBounceStrategy
# STRATEGY_CLASS_PATH=strategies.macd_momentum:MACDMomentumStrategy
# STRATEGY_CLASS_PATH=strategies.breakout:BreakoutStrategy
STRATEGY_CLASS_PATH=

# ── Automation ────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=15
COOLDOWN_SECONDS=60
MAX_SPREAD_PIPS=2.5
ENABLE_SESSION_FILTER=false
SESSION_START_UTC=06:00
SESSION_END_UTC=20:00
JOURNAL_PATH=trade_journal.csv
MAX_CONNECT_RETRIES=5

# ── Advanced Risk Management ─────────────────────────────────
MAX_SYMBOL_OPEN_TRADES=2
MAX_SYMBOL_VOLUME=2.0
ENABLE_BREAK_EVEN=true
BREAK_EVEN_TRIGGER_PIPS=10
BREAK_EVEN_OFFSET_PIPS=1
ENABLE_TRAILING_STOP=true
TRAILING_START_PIPS=15
TRAILING_DISTANCE_PIPS=10
ENABLE_PARTIAL_TP=true
PARTIAL_TP_TRIGGER_PIPS=20
PARTIAL_TP_CLOSE_PCT=0.5
